// Glypho Features

>TB

glypho:h "Glypho (.g)" #ef6c00

shapes:r "6 Shapes\nrect, diamond, circle\noval, pill, hexagon"
edges:r "5 Edge Types\nflow, dashed, thick\nundirected, bidirectional"
groups:r "Groups\nnested containers\nwith labels"
convert:r "Converters\nMermaid, DOT\nJSON Canvas"

@features{shapes edges groups convert}

glypho>shapes
glypho>edges
glypho>groups
glypho>convert
